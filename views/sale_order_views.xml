<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quita el readonly y el group técnico del campo Diario de Facturación
         para poder cambiarlo en suscripciones confirmadas -->
    <record id="sale_subscription_journal_editable" model="ir.ui.view">
        <field name="name">sale.order.form.journal.editable</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <field name="journal_id" position="attributes">
                <attribute name="groups"/>
                <attribute name="readonly"/>
            </field>
        </field>
    </record>
</odoo>

